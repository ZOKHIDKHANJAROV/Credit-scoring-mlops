{
  "uid": "credit-scoring-dashboard",
  "title": "Credit Scoring Monitoring",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Scoring Requests",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "credit_scoring_requests_total",
          "legendFormat": "requests"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Scoring Errors",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "credit_scoring_errors_total",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Last Default Probability",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "credit_scoring_default_probability",
          "legendFormat": "probability"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Last Credit Score",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "credit_scoring_score",
          "legendFormat": "score"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Requests Per Minute",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(credit_scoring_requests_total[1m])",
          "legendFormat": "requests/sec"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "API Latency",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(credit_scoring_request_latency_seconds_sum[1m]) / rate(credit_scoring_request_latency_seconds_count[1m])",
          "legendFormat": "avg latency"
        }
      ]
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "Decision Distribution",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "credit_scoring_decision_total",
          "legendFormat": "{{decision}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "barchart",
      "title": "Risk Level Distribution",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "credit_scoring_risk_level_total",
          "legendFormat": "{{risk_level}}"
        }
      ]
    }
  ]
}